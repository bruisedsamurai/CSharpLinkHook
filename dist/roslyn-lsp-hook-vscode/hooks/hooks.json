{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "cwd": ".",
        "timeoutSec": 30,
        "command": "if (Test-Path \"${CLAUDE_PLUGIN_ROOT}\\RoslynLspHook.exe\") { & \"${CLAUDE_PLUGIN_ROOT}\\RoslynLspHook.exe\" }; exit 0"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "matcher": "edit|create",
        "cwd": ".",
        "timeoutSec": 60,
        "command": "if (Test-Path \"${CLAUDE_PLUGIN_ROOT}\\CSharpLintHook.dll\") { dotnet \"${CLAUDE_PLUGIN_ROOT}\\CSharpLintHook.dll\" hook format }; exit 0"
      },
      {
        "type": "command",
        "matcher": "bash|grep|view|powershell",
        "cwd": ".",
        "timeoutSec": 30,
        "command": "if (Test-Path \"${CLAUDE_PLUGIN_ROOT}\\CSharpLintHook.dll\") { dotnet \"${CLAUDE_PLUGIN_ROOT}\\CSharpLintHook.dll\" hook read }; exit 0"
      },
      {
        "type": "command",
        "cwd": ".",
        "timeoutSec": 30,
        "command": "if (Test-Path \"${CLAUDE_PLUGIN_ROOT}\\RoslynLspHook.exe\") { & \"${CLAUDE_PLUGIN_ROOT}\\RoslynLspHook.exe\" }; exit 0"
      }
    ]
  }
}