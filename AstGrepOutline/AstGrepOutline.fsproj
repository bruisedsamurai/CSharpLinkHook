<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <DisableImplicitFSharpCoreReference>true</DisableImplicitFSharpCoreReference>
        <PublishAot>true</PublishAot>
        <WarningsAsErrors>FS0025,Nullable,FS3260,FS3261,FS3262,FS3263,FS3264,FS3265,FS3268,FS3271,FS00430</WarningsAsErrors>
        <NoWarn>MT7091;NETSDK1206;NU1510</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="Payload.fs"/>
        <Compile Include="Program.fs"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="README.md"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="FSharp.Core" Version="10.1.301"/>
        <PackageReference Include="Thoth.Json.Net" Version="12.0.0"/>
    </ItemGroup>

</Project>
