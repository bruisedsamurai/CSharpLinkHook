{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "matcher": "bash|powershell",
        "cwd": ".",
        "bash": "test -f \"${PLUGIN_ROOT}/CSharpLintHook.dll\" && dotnet \"${PLUGIN_ROOT}/CSharpLintHook.dll\" hook commit-guard || true",
        "powershell": "if (Test-Path \"${PLUGIN_ROOT}\\CSharpLintHook.dll\") { dotnet \"${PLUGIN_ROOT}\\CSharpLintHook.dll\" hook commit-guard }; exit 0",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "matcher": "powershell",
        "cwd": ".",
        "bash": "test -f \"${PLUGIN_ROOT}/PwshLintHook/PwshLintHook.dll\" && dotnet \"${PLUGIN_ROOT}/PwshLintHook/PwshLintHook.dll\" hook tool-guard || true",
        "powershell": "if (Test-Path \"${PLUGIN_ROOT}\\PwshLintHook\\PwshLintHook.dll\") { dotnet \"${PLUGIN_ROOT}\\PwshLintHook\\PwshLintHook.dll\" hook tool-guard }; exit 0",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "matcher": "edit|create",
        "cwd": ".",
        "bash": "test -f \"${PLUGIN_ROOT}/CSharpLintHook.dll\" && dotnet \"${PLUGIN_ROOT}/CSharpLintHook.dll\" hook format || true",
        "powershell": "if (Test-Path \"${PLUGIN_ROOT}\\CSharpLintHook.dll\") { dotnet \"${PLUGIN_ROOT}\\CSharpLintHook.dll\" hook format }; exit 0",
        "timeoutSec": 60
      },
      {
        "type": "command",
        "matcher": "grep|view",
        "cwd": ".",
        "bash": "test -x \"${PLUGIN_ROOT}/AstGrepOutline\" && \"${PLUGIN_ROOT}/AstGrepOutline\" || true",
        "powershell": "if (Test-Path \"${PLUGIN_ROOT}\\AstGrepOutline.exe\") { & \"${PLUGIN_ROOT}\\AstGrepOutline.exe\" }; exit 0",
        "timeoutSec": 30
      }
    ]
  }
}
