{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "cwd": ".",
        "bash": "test -x \"${PLUGIN_ROOT}/RoslynLspHook\" && \"${PLUGIN_ROOT}/RoslynLspHook\" || true",
        "powershell": "if (Test-Path \"${PLUGIN_ROOT}\\RoslynLspHook.exe\") { & \"${PLUGIN_ROOT}\\RoslynLspHook.exe\" }; exit 0",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "matcher": "edit|create",
        "cwd": ".",
        "bash": "test -f \"${PLUGIN_ROOT}/CSharpLintHook.dll\" && dotnet \"${PLUGIN_ROOT}/CSharpLintHook.dll\" hook format || true",
        "powershell": "if (Test-Path \"${PLUGIN_ROOT}\\CSharpLintHook.dll\") { dotnet \"${PLUGIN_ROOT}\\CSharpLintHook.dll\" hook format }; exit 0",
        "timeoutSec": 60
      },
      {
        "type": "command",
        "matcher": "bash|grep|view|powershell",
        "cwd": ".",
        "bash": "test -f \"${PLUGIN_ROOT}/CSharpLintHook.dll\" && dotnet \"${PLUGIN_ROOT}/CSharpLintHook.dll\" hook read || true",
        "powershell": "if (Test-Path \"${PLUGIN_ROOT}\\CSharpLintHook.dll\") { dotnet \"${PLUGIN_ROOT}\\CSharpLintHook.dll\" hook read }; exit 0",
        "timeoutSec": 30
      },
      {
        "type": "command",
        "cwd": ".",
        "bash": "test -x \"${PLUGIN_ROOT}/RoslynLspHook\" && \"${PLUGIN_ROOT}/RoslynLspHook\" || true",
        "powershell": "if (Test-Path \"${PLUGIN_ROOT}\\RoslynLspHook.exe\") { & \"${PLUGIN_ROOT}\\RoslynLspHook.exe\" }; exit 0",
        "timeoutSec": 30
      }
    ]
  }
}
