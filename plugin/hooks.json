{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "cwd": ".",
        "bash": "test -x \"${PLUGIN_ROOT}/RoslynLspHook\" && \"${PLUGIN_ROOT}/RoslynLspHook\" sessionStart || true",
        "powershell": "if (Test-Path \"${PLUGIN_ROOT}\\RoslynLspHook.exe\") { & \"${PLUGIN_ROOT}\\RoslynLspHook.exe\" sessionStart }; exit 0",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "cwd": ".",
        "bash": "test -f \"${PLUGIN_ROOT}/CSharpLintHook.dll\" && dotnet \"${PLUGIN_ROOT}/CSharpLintHook.dll\" hook || true",
        "powershell": "if (Test-Path \"${PLUGIN_ROOT}\\CSharpLintHook.dll\") { dotnet \"${PLUGIN_ROOT}\\CSharpLintHook.dll\" hook }; exit 0",
        "timeoutSec": 60
      },
      {
        "type": "command",
        "cwd": ".",
        "bash": "test -x \"${PLUGIN_ROOT}/RoslynLspHook\" && \"${PLUGIN_ROOT}/RoslynLspHook\" postToolUse || true",
        "powershell": "if (Test-Path \"${PLUGIN_ROOT}\\RoslynLspHook.exe\") { & \"${PLUGIN_ROOT}\\RoslynLspHook.exe\" postToolUse }; exit 0",
        "timeoutSec": 30
      }
    ]
  }
}
