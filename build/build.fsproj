<Project Sdk="Microsoft.NET.Sdk">

    <!-- Standalone build orchestrator (FAKE). Not part of CSharpLintHook.sln. -->
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <DisableImplicitFSharpCoreReference>true</DisableImplicitFSharpCoreReference>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="Program.fs"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="FSharp.Core" Version="10.1.301"/>
        <PackageReference Include="Fake.Core.Target" Version="6.1.4"/>
        <PackageReference Include="Fake.DotNet.Cli" Version="6.1.4"/>
        <PackageReference Include="Fake.IO.FileSystem" Version="6.1.4"/>
    </ItemGroup>

</Project>
